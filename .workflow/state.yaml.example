# .workflow/state.yaml — authoritative cursor for the wf workflow.
# The live file lives next to this one and is git-ignored.
# This example documents the schema.

version: 1

# Path (repo-relative) to the PRD that drives the work.
prd: docs/prd-snake.md

# Detected once at `wf init`. One of: github | gitlab_saas | gitlab_selfhosted | none
host: github

# Origin URL captured at init time.
remote_url: git@github.com:user/repo.git

# Base branch for PRs/MRs.
default_branch: main

# Task ID currently focused on (set by `wf next` / `wf task select`).
current_task: 2

# ISO-8601 timestamps.
created_at: 2026-06-15T08:30:00Z
updated_at: 2026-06-15T09:14:00Z

# One entry per task.
tasks:
  - id: 1
    title: "Render snake grid"
    slug: snake-grid
    branch: feature/snake-grid

    # github_issue | gitlab_issue | local_file
    backend: github_issue

    # URL for issue, or repo-relative path for local_file backend.
    ref: https://github.com/user/repo/issues/4

    # planned | in_progress | in_review | fixing | submitting
    # merged_pending (PR open) | merged | blocked
    status: merged

    # How many review→fix cycles have run.
    review_cycle: 0

    pr_url: https://github.com/user/repo/pull/5
    blocked_reason: null
    started_at: 2026-06-15T08:32:00Z
    updated_at: 2026-06-15T08:58:00Z

  - id: 2
    title: "Add snake movement"
    slug: snake-movement
    branch: feature/snake-movement
    backend: github_issue
    ref: https://github.com/user/repo/issues/6
    status: in_review
    review_cycle: 1
    pr_url: null
    blocked_reason: null
    started_at: 2026-06-15T09:00:00Z
    updated_at: 2026-06-15T09:14:00Z
